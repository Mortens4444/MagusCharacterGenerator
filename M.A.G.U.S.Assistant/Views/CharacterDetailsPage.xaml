<v:NotifierTabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:mv="clr-namespace:M.A.G.U.S.Assistant.Views"
            xmlns:v="clr-namespace:Mtf.LanguageService.MAUI.Views;assembly=Mtf.LanguageService.MAUI"
            xmlns:vm="clr-namespace:M.A.G.U.S.Assistant.ViewModels"
            x:Class="M.A.G.U.S.Assistant.Views.CharacterDetailsPage"
            x:ClassModifier="internal"
            x:DataType="vm:CharacterViewModel">

    <ContentPage Title="⛤">
        <VerticalStackLayout>
            <mv:CharacterOverviewView />
            <mv:HealthView />
        </VerticalStackLayout>
    </ContentPage>

    <ContentPage Title="✨">
        <mv:AbilitiesView />
    </ContentPage>

    <ContentPage Title="⚔">
        <mv:CombatValuesView />
    </ContentPage>

    <ContentPage Title="🧙">
        <mv:PsiManaMagicResistanceView />
    </ContentPage>

    <ContentPage Title="📖">
        <mv:QualificationsView />
    </ContentPage>

    <ContentPage Title="🎒">
        <mv:EquipmentView />
    </ContentPage>

</v:NotifierTabbedPage>
