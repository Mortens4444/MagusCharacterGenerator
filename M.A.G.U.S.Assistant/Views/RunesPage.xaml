<?xml version="1.0" encoding="utf-8" ?>
<v:NotifierPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:v="clr-namespace:Mtf.LanguageService.MAUI.Views;assembly=Mtf.LanguageService.MAUI"
                xmlns:view="clr-namespace:M.A.G.U.S.Assistant.Views"
                xmlns:vm="clr-namespace:M.A.G.U.S.Assistant.ViewModels"
                x:Class="M.A.G.U.S.Assistant.Views.RunesPage"
                x:ClassModifier="internal"
                x:DataType="vm:RunesViewModel"
                Title="Runes">

    <Grid RowDefinitions="Auto,*" Padding="10" RowSpacing="10">

        <Border Grid.Row="0" Stroke="Gray" StrokeThickness="1" Padding="10">
            <VerticalStackLayout Spacing="6">

                <Label Text="Plain text" FontAttributes="Bold"/>
                <Entry Text="{Binding PlainText}" />

                <Label Text="Runes" FontAttributes="Bold"/>
                <Entry Text="{Binding RuneText}" />

            </VerticalStackLayout>
        </Border>

        <view:SearchListView Grid.Row="1" />
    </Grid>

</v:NotifierPage>